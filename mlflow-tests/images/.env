TEST_RESULTS_DIR="${TEST_RESULTS_DIR:-/mlflow/results}"
S3_SECRET_NAME="${S3_SECRET_NAME:-mlflow-s3-secret}"
DB_SECRET_NAME="${DB_SECRET_NAME:-mlflow-db-secret}"

# Leave these blank so deploy.py uses its internal defaults when deploying
# self-managed postgres (postgres-service.<namespace>.svc.cluster.local).
# Set them explicitly only when pointing at a pre-existing external database.
DB_HOST="${DB_HOST:-}"
DB_PORT="${DB_PORT:-}"
DB_USER="${DB_USER:-}"
DB_PASSWORD="${DB_PASSWORD:-}"
DB_NAME="${DB_NAME:-}"
